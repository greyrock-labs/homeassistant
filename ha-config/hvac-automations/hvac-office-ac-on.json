{"id": "1781193064545", "alias": "HVAC - Office AC: On", "description": "When office_ac turns on: set office HVAC to cool at setpoint_cool_office_override immediately (works in both Cool and Off season). If season is Heat, roll the boolean back off (AC and heat cannot run together).", "triggers": [{"entity_id": "input_boolean.office_ac", "to": "on", "trigger": "state"}], "conditions": [], "actions": [{"choose": [{"conditions": [{"condition": "state", "entity_id": "input_select.hvac_season", "state": "Heat"}], "sequence": [{"action": "input_boolean.turn_off", "target": {"entity_id": "input_boolean.office_ac"}}]}, {"conditions": [{"condition": "state", "entity_id": "input_select.hvac_season", "state": "Cool"}], "sequence": [{"action": "climate.set_hvac_mode", "data": {"hvac_mode": "cool"}, "target": {"entity_id": "climate.hvac_office_hvac_office"}}, {"action": "climate.set_temperature", "data": {"temperature": "{{ states('input_number.setpoint_cool_office_override') | float }}"}, "target": {"entity_id": "climate.hvac_office_hvac_office"}}]}], "default": [{"action": "climate.set_hvac_mode", "data": {"hvac_mode": "cool"}, "target": {"entity_id": "climate.hvac_office_hvac_office"}}, {"action": "climate.set_temperature", "data": {"temperature": "{{ states('input_number.setpoint_cool_office_override') | float }}"}, "target": {"entity_id": "climate.hvac_office_hvac_office"}}]}]}], "mode": "single", "initial_state": true}